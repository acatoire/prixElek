{
  "name": "prixelek",
  "version": "0.1.0",
  "description": "Lightweight business tool for independent electricians - Price comparison application",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "type-check": "tsc --noEmit",
    "lint": "eslint src --ext .ts,.tsx,.vue",
    "lint:fix": "eslint src --ext .ts,.tsx,.vue --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,vue,json,css}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,vue,json,css}\"",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:ui": "vitest --ui",
    "test:ci": "vitest run --coverage --reporter=verbose"
  },
  "dependencies": {
    "vue": "^3.3.4",
    "pinia": "^2.1.6",
    "axios": "^1.6.0"
  },
  "devDependencies": {
    "typescript": "^5.2.2",
    "@vitejs/plugin-vue": "^4.5.0",
    "vite": "^5.0.0",
    "vitest": "^0.34.6",
    "@vitest/ui": "^0.34.6",
    "@vitest/coverage-v8": "^0.34.6",
    "@vue/test-utils": "^2.4.1",
    "eslint": "^8.50.0",
    "eslint-plugin-vue": "^9.17.0",
    "@typescript-eslint/eslint-plugin": "^6.13.0",
    "@typescript-eslint/parser": "^6.13.0",
    "prettier": "^3.1.0",
    "tailwindcss": "^3.3.6",
    "autoprefixer": "^10.4.16",
    "postcss": "^8.4.31"
  },
  "engines": {
    "node": ">=14.0.0",
    "npm": ">=6.0.0"
  },
  "keywords": [
    "electrician",
    "price-comparison",
    "supplier",
    "business-tool",
    "vue",
    "typescript"
  ],
  "author": "prixElek Contributors",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/yourusername/prixElek.git"
  },
  "bugs": {
    "url": "https://github.com/yourusername/prixElek/issues"
  },
  "homepage": "https://github.com/yourusername/prixElek#readme"
}




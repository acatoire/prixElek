# prixElek Environment Variables Template
# Copy this file to .env and fill in your actual values
# NEVER commit .env to git (it contains sensitive credentials)

# Application Environment
NODE_ENV=development
DEBUG=prixelek:*

# API & Server Configuration
VITE_API_BASE_URL=http://localhost:5173
PORT=5173

# Supplier Credentials (Example - fill with your actual credentials)
# These are stored locally and never sent to external servers
REXEL_USERNAME=your_rexel_email@example.com
REXEL_PASSWORD=your_rexel_password
REXEL_API_TOKEN=

SONEPAR_USERNAME=your_sonepar_email@example.com
SONEPAR_PASSWORD=your_sonepar_password
SONEPAR_API_TOKEN=

YESSS_USERNAME=your_yesss_email@example.com
YESSS_PASSWORD=your_yesss_password
YESSS_API_TOKEN=

MATERIELELECTRIQUE_USERNAME=your_materielelectrique_email@example.com
MATERIELELECTRIQUE_PASSWORD=your_materielelectrique_password
MATERIELELECTRIQUE_API_TOKEN=

# Feature Flags (V2 features disabled by default)
VITE_ENABLE_QUOTE_MODULE=false
VITE_ENABLE_DISCOUNT_MODULE=false
VITE_ENABLE_PRICE_HISTORY=false

# Caching & Performance
VITE_CACHE_TTL_MINUTES=15
VITE_REQUEST_TIMEOUT_MS=10000
VITE_MAX_RETRIES=3

# Logging
VITE_LOG_LEVEL=info
VITE_LOG_TO_FILE=false

# Testing
TEST_ENV=false
MOCK_SUPPLIERS=false

